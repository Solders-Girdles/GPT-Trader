/* Sparkline Widget */
SparklineWidget {
    width: 1fr;
    height: 1;
    background: transparent;
    color: $accent;
}

/* Progress Bar Widget */
ProgressBarWidget {
    width: 100%;
    height: 1;
    color: $text-muted;
}

/* Progress / sparkline primitives only; status badges removed (unused widget). */
